        <field name="name">Ver Portal de Socios</field>
        <field name="url">/my/loans</field>
        <field name="target">self</field>
    </record>

    <menuitem id="menu_library_root" 
              name="Biblioteca" 
              sequence="10"/>

    <menuitem id="menu_library_catalog" 
              name="Catalogo" 
              parent="menu_library_root" 
              sequence="10"/>

    <menuitem id="menu_library_books" 
              name="Libros" 
              parent="menu_library_catalog" 
              action="action_library_book" 
              sequence="10"/>
    <menuitem id="menu_library_loans" 
            name="Préstamos" 
            parent="menu_library_catalog" 
            action="action_library_loan" 
            sequence="20"/>
    <menuitem id="menu_library_portal_link"
          name="Portal"
          parent="menu_library_catalog" 
          action="action_view_portal_loans"
          sequence="100"/>
</odoo>