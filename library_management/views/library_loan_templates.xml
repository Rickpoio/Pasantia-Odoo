<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="email_template_loan_expired" model="mail.template">
        <field name="name">Préstamo Vencido: Notificación al Socio</field>
        <field name="model_id" ref="library_management.model_library_loan"/>
        <field name="subject">Aviso: Su préstamo del libro {{ object.book_id.name }} ha vencido</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Hola <t t-out="object.partner_id.name"/><br/><br/>
                    Le informamos que el plazo de 30 días para la devolución del libro 
                    <strong><t t-out="object.book_id.name"/></strong> ha expirado.
                    <br/><br/>
                    Por favor, acuda a la biblioteca para regularizar su situación.
                    <br/><br/>
                    Atentamente,<br/>
                    Gestión de Biblioteca
                </p>
            </div>
        </field>
    </record>
</odoo>