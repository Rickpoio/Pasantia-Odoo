<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_book_tree" model="ir.ui.view">
        <field name="name">library.book.tree</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="author_id"/>
                <field name="publication_date"/>
                <field name="years_since_publication"/>
                <field name="is_available" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="author_id"/>
                <filter string="Disponibles" name="available" domain="[('is_available', '=', True)]"/>
                <filter string="No Disponibles" name="not_available" domain="[('is_available', '=', False)]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Autor" name="group_author" context="{'group_by': 'author_id'}"/>
                    <filter string="Año de Publicación" name="group_year" context="{'group_by': 'publication_date:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Catálogo de Libros</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>